@model CategoryListViewModel

<div class="text-center my-5 border-bottom">
    <div class="display-6">Categories</div>
</div>

<div class="text-center">
    <div class="d-flex justify-content-end my-3">
        <a class="btn btn-outline-success" asp-action="Create">
            <i class="fa fa-plus"></i>
            Create
        </a>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>Category Name</th>
            <th>Operations</th>
        </tr>
    </thead>

    <tbody>
        @foreach (Category cat in Model.Categories)
        {
            <tr>
                <td>@cat.CategoryId</td>

                <td>@cat.CategoryName</td>

                <td>
                    <div class="btn-group">

                        <a class="btn btn-warning"
                            data-toggle="tooltip" data-placement="top" title="Edit"
                           asp-action="Update"
                           asp-route-id="@cat.CategoryId">
                            <i class="fa fa-edit"></i>
                        </a>

                        <a class="btn btn-danger"
                        data-toggle="tooltip" data-placement="top" title="Delete"
                           asp-action="Delete"
                           asp-route-id="@cat.CategoryId">
                            <i class="fa fa-trash"></i>
                        </a>

                    </div>
                </td>

            </tr>
        }
    </tbody>

</table>
<div class="text-center">
            <div page-model="@Model?.Pagination" page-action="Index" page-classes-enabled="true" page-class="btn"
                page-class-normal="btn-outline-dark" page-class-selected="btn-secondary" class="btn-group">
            </div>
        </div>

@section Scripts
    {
    <script type="text/javascript">
        $(document).ready(() => {
            $('[data-toggle="tooltip"]').tooltip()
        });
    </script>
}